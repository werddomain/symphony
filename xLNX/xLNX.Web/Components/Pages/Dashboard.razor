@page "/"

<PageTitle>Dashboard — Symphony xLNX</PageTitle>

<div class="page-header">
    <h1>Dashboard</h1>
    <div>
        <button class="btn btn-primary" @onclick="RefreshDataAsync">Refresh</button>
        <button class="btn btn-secondary" @onclick="TriggerPollAsync">Trigger Poll</button>
    </div>
</div>

@if (_error is not null)
{
    <div class="error-banner">@_error</div>
}

@if (_state is null)
{
    <div class="loading">Loading state…</div>
}
else
{
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Running</div>
            <div class="stat-value">@_state.Running.Count</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Retrying</div>
            <div class="stat-value warning">@_state.RetryAttempts.Count</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Total Tokens</div>
            <div class="stat-value">@FormatTokens(GetTotalTokens())</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Runtime</div>
            <div class="stat-value">@FormatRuntime(GetSecondsRunning())</div>
        </div>
    </div>

    <div class="card">
        <h2>Running Sessions</h2>
        @if (_state.Running.Count == 0)
        {
            <div class="empty-state">No active sessions</div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Identifier</th>
                        <th>State</th>
                        <th>Session</th>
                        <th>Turns</th>
                        <th>Last Event</th>
                        <th>Tokens</th>
                        <th>Started</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in _state.Running.Values)
                    {
                        <tr>
                            <td><a href="/issues/@entry.Identifier">@entry.Identifier</a></td>
                            <td><span class="badge badge-running">@entry.Issue.State</span></td>
                            <td>@TruncateSessionId(entry.Session.SessionId)</td>
                            <td>@entry.Session.TurnCount</td>
                            <td>@(entry.Session.LastCodexEvent ?? "—")</td>
                            <td>@FormatTokens(entry.Session.CodexTotalTokens)</td>
                            <td>@FormatTimeAgo(entry.StartedAt)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="card">
        <h2>Retry Queue</h2>
        @if (_state.RetryAttempts.Count == 0)
        {
            <div class="empty-state">No pending retries</div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Identifier</th>
                        <th>Attempt</th>
                        <th>Due At</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in _state.RetryAttempts.Values)
                    {
                        <tr>
                            <td><a href="/issues/@entry.Identifier">@entry.Identifier</a></td>
                            <td>@entry.Attempt</td>
                            <td>@FormatDueAt(entry.DueAtMs)</td>
                            <td>@(entry.Error ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (_state.CodexRateLimits is not null)
    {
        <div class="card">
            <h2>Rate Limits</h2>
            <div class="code-block">@System.Text.Json.JsonSerializer.Serialize(_state.CodexRateLimits, _jsonOptions)</div>
        </div>
    }
}
